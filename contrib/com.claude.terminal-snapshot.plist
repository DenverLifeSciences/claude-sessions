<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude.terminal-snapshot</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR-USER/path/to/claude-sessions</string>
    <string>--snapshot</string>
  </array>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/tmp/claude-terminal-snapshot.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/claude-terminal-snapshot.log</string>
</dict>
</plist>
