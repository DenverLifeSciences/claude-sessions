#!/usr/bin/env bash
# claude-sessions — cross-project Claude Code session picker.
#
# Lists every session under ~/.claude/projects (all directories, newest first)
# in fzf. Enter opens the highlighted session in its own window running
# `claude --resume <id>` interactively (so its summary-vs-full prompt appears
# there), while the picker stays open for the next one:
#   - inside tmux  -> new tmux window
#   - otherwise    -> new TAB in the current iTerm window (Terminal.app fallback)
#
# Keys: enter=open  ctrl-r=refresh  esc=quit
set -euo pipefail

# BASH_SOURCE is unset when piped (curl ... | bash -s -- --install)
SELF="${BASH_SOURCE[0]:-$0}"
[ -f "$SELF" ] && SELF="$(cd "$(dirname "$SELF")" && pwd)/$(basename "$SELF")"
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude || echo claude)}"
MAX_SESSIONS="${CLAUDE_SESSIONS_MAX:-300}"

# ---------------------------------------------------------------- list -----
# Emits tab-separated lines: session_id <TAB> cwd <TAB> jsonl_path <TAB> display
# $1 = "all" (default) or "main" (hide teammate/agent sessions)
list_sessions() {
  python3 - "$MAX_SESSIONS" "${1:-all}" <<'PY'
import glob, json, os, re, signal, sys, time
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

max_n, mode = int(sys.argv[1]), sys.argv[2]
root = os.path.expanduser("~/.claude/projects")
files = [f for f in glob.glob(os.path.join(root, "*", "*.jsonl"))
         if not os.path.basename(f).startswith("agent-")]
files.sort(key=os.path.getmtime, reverse=True)

DIM, CYAN, YELLOW, MAGENTA, RESET = "\033[2m", "\033[36m", "\033[33m", "\033[35m", "\033[0m"

def age(ts):
    s = int(time.time() - ts)
    if s < 3600: return f"{s // 60}m"
    if s < 86400: return f"{s // 3600}h"
    return f"{s // 86400}d"

def first_text(content):
    if isinstance(content, str): return content
    if isinstance(content, list):
        for part in content:
            if isinstance(part, dict) and part.get("type") == "text":
                return part.get("text", "")
    return ""

shown = 0
home = os.path.expanduser("~")
for f in files:
    if shown >= max_n: break
    sid = cwd = branch = agent = ""
    title = summary = raw = ""
    try:
        with open(f, errors="replace") as fh:
            for i, line in enumerate(fh):
                if i > 40 or (title and cwd): break
                try: e = json.loads(line)
                except Exception: continue
                if e.get("type") == "summary" and not summary:
                    summary = e.get("summary", "")
                if e.get("type") == "user" and not e.get("isSidechain"):
                    sid = sid or e.get("sessionId", "")
                    cwd = cwd or e.get("cwd", "")
                    branch = branch or (e.get("gitBranch") or "")
                    agent = agent or (e.get("agentName") or "")
                    if not title:
                        t = first_text(e.get("message", {}).get("content", "")).strip()
                        if t.startswith("Caveat:"):
                            t = t.split("\n", 1)[-1].strip()
                        raw = raw or t
                        if t and not t.startswith("<"):
                            title = t
    except OSError:
        continue
    if not sid or not cwd:
        continue
    is_agent = bool(agent) and agent != "team-lead"
    if mode == "main" and is_agent:
        continue
    if not title and raw:  # e.g. teammate prompts wrapped in injected <tags>
        title = re.sub(r"<[^>]*>", " ", raw)
    title = " ".join((title or summary or "(no message)").split())[:120]
    proj = cwd.replace(home, "~")
    if len(proj) > 34: proj = "…" + proj[-33:]
    br = f" {YELLOW}{branch[:14]}{RESET}" if branch and branch not in ("main", "master", "HEAD") else ""
    tag = f" {MAGENTA}⛭ {agent[:18]}{RESET}" if is_agent else ""
    display = (f"{DIM}{age(os.path.getmtime(f)):>3}{RESET} "
               f"{CYAN}{proj:<34}{RESET}{tag}{br} {title}")
    print(f"{sid}\t{cwd}\t{f}\t{display}")
    shown += 1
PY
}

# ------------------------------------------------------------- preview -----
preview_session() {
  python3 - "$1" <<'PY'
import json, os, sys

path = sys.argv[1]
size = os.path.getsize(path)
with open(path, "rb") as fh:
    if size > 300_000:
        fh.seek(-300_000, 2)
        fh.readline()  # drop partial line
    lines = fh.read().decode(errors="replace").splitlines()

BOLD, GREEN, BLUE, RESET = "\033[1m", "\033[32m", "\033[34m", "\033[0m"
out = []
for line in lines:
    try: e = json.loads(line)
    except Exception: continue
    role = e.get("type")
    if role not in ("user", "assistant") or e.get("isSidechain"): continue
    c = e.get("message", {}).get("content", "")
    if isinstance(c, list):
        c = "\n".join(p.get("text", "") for p in c
                      if isinstance(p, dict) and p.get("type") == "text")
    if not isinstance(c, str) or not c.strip() or c.startswith("<"): continue
    tag = f"{GREEN}{BOLD}user{RESET}" if role == "user" else f"{BLUE}{BOLD}claude{RESET}"
    out.append(f"{tag}: {c.strip()[:600]}")
print(f"\n\n".join(out[-15:]) or "(no readable messages)")
PY
}

# ---------------------------------------------------------------- open -----
open_one() {
  local id="$1" cwd="$2"
  [ -d "$cwd" ] || cwd="$HOME"
  if [ -n "${TMUX:-}" ]; then
    tmux new-window -c "$cwd" -n "$(basename "$cwd")" "$CLAUDE_BIN --resume $id"
  elif [ "${TERM_PROGRAM:-}" = "iTerm.app" ] || ps -axo comm | grep -q "MacOS/iTerm2$"; then
    osascript - "$cwd" "$id" "$CLAUDE_BIN" <<'EOF' >/dev/null
on run argv
  set theCmd to "cd " & quoted form of item 1 of argv & " && " & item 3 of argv & " --resume " & item 2 of argv
  tell application "iTerm"
    activate
    if (count of windows) is 0 then
      create window with default profile
    else
      tell current window to create tab with default profile
    end if
    tell current session of current window to write text theCmd
  end tell
end run
EOF
  else
    osascript - "$cwd" "$id" "$CLAUDE_BIN" <<'EOF' >/dev/null
on run argv
  set theCmd to "cd " & quoted form of item 1 of argv & " && " & item 3 of argv & " --resume " & item 2 of argv
  tell application "Terminal"
    activate
    do script theCmd
  end tell
end run
EOF
  fi
}

open_line() {  # $1 = file containing the highlighted tab-delimited line
  IFS=$'\t' read -r id cwd _rest < "$1"
  [ -n "$id" ] && open_one "$id" "$cwd"
}

# ------------------------------------------------------------ snapshot -----
# Dumps every iTerm tab (cwd + running claude session id, if any) to
# $SNAPSHOT_FILE. Run periodically (launchd) so a machine crash can be
# undone with --restore-crash. Skips writing when iTerm has no tabs, so a
# post-reboot run never clobbers the last good snapshot.
SNAPSHOT_FILE="${CLAUDE_SESSIONS_SNAPSHOT:-$HOME/.claude/terminal-snapshot.json}"
SNAPSHOT_DIR="${CLAUDE_SESSIONS_SNAPSHOT_DIR:-$HOME/.claude/terminal-snapshots}"
INSTALL_PATH="${CLAUDE_SESSIONS_INSTALL:-$HOME/.local/bin/claude-sessions}"
RAW_URL="https://raw.githubusercontent.com/DenverLifeSciences/claude-sessions/main/claude-sessions"
PLIST="$HOME/Library/LaunchAgents/com.claude.terminal-snapshot.plist"
UPDATE_CACHE="${CLAUDE_SESSIONS_UPDATE_CACHE:-$HOME/.claude/.claude-sessions-update}"
UPDATE_TTL="${CLAUDE_SESSIONS_UPDATE_TTL:-86400}"  # re-check GitHub at most once/day

# --------------------------------------------------------- install/update --
# GitHub is the single source of truth. --install fetches the latest script to
# a LOCAL path (launchd cannot read iCloud/cloud-synced paths — macOS TCC),
# wires up PATH + `cs` alias, and loads the snapshot timer. --update refreshes
# the installed copy in place. Both are idempotent; rerun freely.
self_install() {
  command -v python3 >/dev/null || { echo "missing dependency: python3" >&2; exit 1; }
  command -v fzf >/dev/null || echo "WARNING: fzf not found (brew install fzf) — picker won't work until installed" >&2
  mkdir -p "$(dirname "$INSTALL_PATH")"
  if curl -fsSL "$RAW_URL" -o "$INSTALL_PATH.tmp" 2>/dev/null; then
    mv "$INSTALL_PATH.tmp" "$INSTALL_PATH"
    echo "installed latest from GitHub -> $INSTALL_PATH"
  elif [ -f "$SELF" ] && [ "$SELF" != "$INSTALL_PATH" ]; then
    cp "$SELF" "$INSTALL_PATH"
    echo "offline: copied $SELF -> $INSTALL_PATH"
  else
    echo "install failed: cannot reach GitHub and no local copy to fall back on" >&2; exit 1
  fi
  chmod +x "$INSTALL_PATH"

  local zshrc="$HOME/.zshrc"
  grep -qs '/.local/bin' "$zshrc" || printf '\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$zshrc"
  grep -qs 'alias cs=' "$zshrc" || printf "alias cs='claude-sessions'\n" >> "$zshrc"

  cat > "$PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.claude.terminal-snapshot</string>
  <key>ProgramArguments</key>
  <array><string>$INSTALL_PATH</string><string>--snapshot</string></array>
  <key>StartInterval</key><integer>300</integer>
  <key>RunAtLoad</key><false/>
  <key>StandardOutPath</key><string>/tmp/claude-terminal-snapshot.log</string>
  <key>StandardErrorPath</key><string>/tmp/claude-terminal-snapshot.log</string>
</dict>
</plist>
EOF
  launchctl bootout "gui/$(id -u)/com.claude.terminal-snapshot" 2>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "$PLIST"
  echo "snapshot timer loaded (every 5 min) -> $SNAPSHOT_DIR"
  echo "done — open a new shell and run: cs"
}

self_update() {
  local target="$INSTALL_PATH"
  [ -f "$target" ] || target="$SELF"
  curl -fsSL "$RAW_URL" -o "$target.tmp" || { echo "update failed: cannot reach GitHub" >&2; exit 1; }
  if cmp -s "$target.tmp" "$target"; then
    rm -f "$target.tmp"; echo "already up to date: $target"
  else
    mv "$target.tmp" "$target" && chmod +x "$target"
    echo "updated $target"
  fi
}

# ------------------------------------------------------- update notifier ---
# The picker nags (once) when a newer version is on GitHub, WITHOUT ever
# blocking on the network: update_check_bg refreshes a cached flag in the
# background (throttled to UPDATE_TTL), update_notice reads that cache and
# prints instantly. So the notice reflects the *previous* run's check — which
# is exactly right for an update reminder. Cache line: "<checked-epoch> <0|1>".
update_check_bg() {
  [ -t 2 ] || return 0  # only from an interactive terminal, never launchd
  local now checked=0
  now=$(date +%s)
  [ -f "$UPDATE_CACHE" ] && read -r checked _ < "$UPDATE_CACHE" 2>/dev/null || true
  case "$checked" in ''|*[!0-9]*) checked=0 ;; esac
  [ $(( now - checked )) -ge "$UPDATE_TTL" ] || return 0  # checked recently
  ( target="$INSTALL_PATH"; [ -f "$target" ] || target="$SELF"
    tmp="$(mktemp)" || exit 0
    if curl -fsSL --max-time 5 "$RAW_URL" -o "$tmp" 2>/dev/null; then
      a=0; cmp -s "$tmp" "$target" || a=1
      printf '%s %s\n' "$(date +%s)" "$a" > "$UPDATE_CACHE"
    fi
    rm -f "$tmp" ) >/dev/null 2>&1 &
}

update_notice() {
  [ -t 2 ] || return 0
  local avail=0
  [ -f "$UPDATE_CACHE" ] && read -r _ avail < "$UPDATE_CACHE" 2>/dev/null || true
  [ "$avail" = "1" ] && printf '\033[33m▲ claude-sessions: a newer version is on GitHub — run `claude-sessions --update`\033[0m\n' >&2
  return 0
}

snapshot_state() {
  local dump
  dump=$(osascript <<'EOF' 2>/dev/null
set out to ""
tell application "iTerm"
  repeat with w in windows
    repeat with t in tabs of w
      repeat with s in sessions of t
        set out to out & (id of w) & "|" & (tty of s) & linefeed
      end repeat
    end repeat
  end repeat
end tell
return out
EOF
) || true
  SNAP_DUMP="$dump" python3 - "$SNAPSHOT_FILE" "$SNAPSHOT_DIR" <<'PY'
import glob, json, os, re, subprocess, sys, time

out_path, snap_dir = sys.argv[1], sys.argv[2]

def is_teammate(sid):
    # A TeamCreate teammate's transcript carries an `agentName` field; the
    # session you drove (or a solo session) has none, and the team lead is
    # "team-lead" — both count as yours. iTerm's tmux control-mode integration
    # surfaces each teammate pane as a native session, so the snapshot walk sees
    # them; skip so --restore-crash never resurrects a subagent window.
    if not sid: return False
    for f in glob.glob(os.path.expanduser("~/.claude/projects/*/" + sid + ".jsonl")):
        try:
            with open(f, errors="replace") as fh:
                for i, line in enumerate(fh):
                    if i > 60: break
                    try: e = json.loads(line)
                    except Exception: continue
                    if "agentName" in e:
                        a = e.get("agentName") or ""
                        return bool(a) and a != "team-lead"
        except OSError:
            pass
    return False

tabs = []
for line in os.environ.get("SNAP_DUMP", "").splitlines():
    if "|" not in line: continue
    win, tty = line.split("|", 1)
    tty = tty.strip().replace("/dev/", "")
    if not tty: continue
    try:
        ps = subprocess.run(["ps", "-t", tty, "-o", "pid=,command="],
                            capture_output=True, text=True, timeout=10).stdout
    except Exception:
        continue
    shell_pid = claude_pid = None
    resume_id = None
    for pline in ps.splitlines():
        parts = pline.strip().split(None, 1)
        if len(parts) != 2: continue
        pid, cmd = parts
        if shell_pid is None and re.search(r"(^|/)-?(zsh|bash|fish)", cmd):
            shell_pid = pid
        if claude_pid is None and re.search(r"(^|/)claude( |$)", cmd):
            claude_pid = pid
            m = re.search(r"--resume[= ]([0-9a-f-]{36})", cmd)
            if m: resume_id = m.group(1)

    def cwd_of(pid):
        try:
            out = subprocess.run(["lsof", "-a", "-p", pid, "-d", "cwd", "-Fn"],
                                 capture_output=True, text=True, timeout=10).stdout
            for l in out.splitlines():
                if l.startswith("n"): return l[1:]
        except Exception:
            pass
        return None

    cwd = cwd_of(claude_pid or shell_pid) if (claude_pid or shell_pid) else None
    if not cwd: continue

    sid = resume_id
    if claude_pid and not sid:
        # exact match: the transcript claude holds open
        try:
            out = subprocess.run(["lsof", "-p", claude_pid, "-Fn"],
                                 capture_output=True, text=True, timeout=10).stdout
            m = re.search(r"\.claude/projects/[^\n]*/([0-9a-f-]{36})\.jsonl", out)
            if m: sid = m.group(1)
        except Exception:
            pass
    if claude_pid and not sid:
        # fallback: newest transcript for this cwd's project dir
        proj = os.path.expanduser("~/.claude/projects/") + re.sub(r"[/.]", "-", cwd)
        try:
            js = [os.path.join(proj, f) for f in os.listdir(proj) if f.endswith(".jsonl")]
            if js: sid = os.path.basename(max(js, key=os.path.getmtime))[:-6]
        except OSError:
            pass
    if is_teammate(sid):  # subagent/teammate window — not one of the user's
        continue
    tabs.append({"window": win.strip(), "cwd": cwd, "claudeSession": sid})

if not tabs:  # never overwrite a good snapshot with an empty one
    print("snapshot: no iTerm tabs found; keeping previous snapshots")
    sys.exit(0)

os.makedirs(snap_dir, exist_ok=True)
history = sorted(glob.glob(os.path.join(snap_dir, "*.json")))
if history:
    try:
        if json.load(open(history[-1])).get("tabs") == tabs:
            print(f"snapshot: unchanged ({len(tabs)} tab(s)); keeping {history[-1]}")
            sys.exit(0)
    except Exception:
        pass

data = {"takenAt": int(time.time()), "tabs": tabs}
hist_path = os.path.join(snap_dir, f"{data['takenAt']}.json")
json.dump(data, open(hist_path, "w"), indent=1)
for old in history[:-100]:  # keep last ~100 distinct states
    os.remove(old)
print(f"snapshot: {len(tabs)} tab(s) -> {hist_path}")
PY
}

restore_crash() {  # $1 (optional) = specific snapshot file; default: newest
  python3 - "${1:-}" "$SNAPSHOT_FILE" "$SNAPSHOT_DIR" "$CLAUDE_BIN" <<'PY'
import glob, json, os, shlex, subprocess, sys, time

arg, latest, snap_dir, claude_bin = sys.argv[1:5]

def is_teammate(sid):
    # See snapshot_state: teammate transcripts carry a non-"team-lead" agentName.
    # Applied here too so OLD snapshots (taken before snapshot-time filtering)
    # don't resurrect subagent windows.
    if not sid: return False
    for f in glob.glob(os.path.expanduser("~/.claude/projects/*/" + sid + ".jsonl")):
        try:
            with open(f, errors="replace") as fh:
                for i, line in enumerate(fh):
                    if i > 60: break
                    try: e = json.loads(line)
                    except Exception: continue
                    if "agentName" in e:
                        a = e.get("agentName") or ""
                        return bool(a) and a != "team-lead"
        except OSError:
            pass
    return False

def n_sessions(p):  # the user's own live claude sessions in a snapshot file
    try:
        return sum(1 for t in json.load(open(p)).get("tabs", [])
                   if t.get("claudeSession") and not is_teammate(t["claudeSession"]))
    except Exception:
        return 0

path = arg
if not path:
    # Default: newest snapshot that actually has live claude sessions. A reboot
    # (or sleep/crash) kills every claude process but iTerm restores the bare
    # shells, so the first post-reboot snapshot has tabs but 0 sessions — a husk.
    # Skip those so `--restore-crash` never lands on a session-less state.
    history = sorted(glob.glob(os.path.join(snap_dir, "*.json")))  # oldest -> newest
    healthy = [p for p in history if n_sessions(p) > 0]
    if healthy:
        path = healthy[-1]
        skipped = len(history) - 1 - history.index(path)
        if skipped:
            print(f"skipped {skipped} newer session-less snapshot(s) (likely post-reboot "
                  f"shells); restoring newest snapshot with live sessions")
    elif history:
        path = history[-1]
        print("warning: no snapshot has live claude sessions; restoring newest anyway")
    else:
        path = latest
if not path or not os.path.exists(path):
    sys.exit("no snapshot found (looked in %s and %s)" % (snap_dir, latest))
snap = json.load(open(path))
age_min = (time.time() - snap["takenAt"]) / 60
all_tabs = snap["tabs"]
tabs = [t for t in all_tabs if not is_teammate(t.get("claudeSession"))]
skipped_agents = len(all_tabs) - len(tabs)
snap["tabs"] = tabs
if skipped_agents:
    print(f"skipped {skipped_agents} subagent/teammate window(s)")
print(f"restoring {len(snap['tabs'])} tab(s) from {path} (taken {age_min:.0f} min ago)")

# All snapshot tabs are restored as tabs of the CURRENT window (the one the
# command runs in), regardless of how they were grouped into windows before —
# one window to rule them all, and the initiating tab is left untouched.
script = ['tell application "iTerm"', "activate",
          "if (count of windows) is 0 then create window with default profile"]
for tab in snap["tabs"]:
    cmd = "cd " + shlex.quote(tab["cwd"])
    if tab.get("claudeSession"):
        cmd += f" && {claude_bin} --resume {tab['claudeSession']}"
    esc = cmd.replace("\\", "\\\\").replace('"', '\\"')
    script.append("tell current window to create tab with default profile")
    script.append(f'tell current session of current window to write text "{esc}"')
script.append("end tell")
subprocess.run(["osascript", "-e", "\n".join(script)], check=True)
for tab in snap["tabs"]:
    mark = "claude --resume " + tab["claudeSession"] if tab.get("claudeSession") else "shell"
    print(f"  {tab['cwd']}  [{mark}]")
PY
}

pick_snapshot() {  # browse snapshot history in fzf, restore the chosen one
  local chosen
  chosen=$(python3 - "$SNAPSHOT_DIR" <<'PY'
import glob, json, os, sys, time
for f in sorted(glob.glob(os.path.join(sys.argv[1], "*.json")), reverse=True):
    try: s = json.load(open(f))
    except Exception: continue
    mins = int((time.time() - s["takenAt"]) / 60)
    age = f"{mins}m" if mins < 60 else (f"{mins//60}h" if mins < 1440 else f"{mins//1440}d")
    n_claude = sum(1 for t in s["tabs"] if t.get("claudeSession"))
    cwds = ", ".join(sorted({os.path.basename(t["cwd"]) or "~" for t in s["tabs"]})[:4])
    print(f"{f}\t{age:>4} ago  {len(s['tabs'])} tabs ({n_claude} claude)  {cwds}")
PY
) || true
  [ -n "$chosen" ] || { echo "no snapshots in $SNAPSHOT_DIR" >&2; exit 1; }
  chosen=$(echo "$chosen" | fzf --delimiter '\t' --with-nth 2.. --no-sort \
    --header 'pick the terminal state to restore' | cut -f1)
  [ -n "$chosen" ] && restore_crash "$chosen"
}

usage() {
  cat >&2 <<'EOF'
usage: claude-sessions                    interactive session picker (fzf)
       claude-sessions --snapshot        snapshot iTerm tabs + claude sessions
       claude-sessions --restore-crash [file]
                                         restore newest (or given) snapshot
       claude-sessions --restore-pick    choose a snapshot from history to restore
       claude-sessions --list [all|main] print sessions (tab-separated)
       claude-sessions --install         set up on this machine (script, PATH, cs alias, snapshot timer)
       claude-sessions --update          refresh installed copy from GitHub
EOF
  exit 2
}

# ---------------------------------------------------------------- main -----
case "${1:-}" in
  --list)       list_sessions "${2:-all}" ;;
  --preview)    preview_session "$2" ;;
  --open-line)  open_line "$2" ;;
  --snapshot)      snapshot_state ;;
  --restore-crash) restore_crash "${2:-}" ;;
  --restore-pick)  pick_snapshot ;;
  --install)       self_install ;;
  --update)        self_update ;;
  -h|--help)       usage ;;
  ?*)              echo "claude-sessions: unknown argument: $1" >&2; usage ;;
  *)
    update_check_bg
    list_sessions | fzf --ansi --delimiter '\t' --with-nth 4.. \
      --no-sort --layout=reverse --info=inline \
      --header 'enter: open in new tab (picker stays)  |  ctrl-a: hide/show ⛭ agents  |  ctrl-r: refresh  |  esc: quit' \
      --preview "'$SELF' --preview {3}" --preview-window 'right,50%,wrap' \
      --bind "enter:execute-silent('$SELF' --open-line {f})" \
      --bind "ctrl-r:reload('$SELF' --list all)" \
      --bind "ctrl-a:transform:[ \"\$FZF_PROMPT\" = 'main> ' ] \
        && echo \"change-prompt(> )+reload('$SELF' --list all)\" \
        || echo \"change-prompt(main> )+reload('$SELF' --list main)\"" \
      >/dev/null || true
    update_notice
    ;;
esac
